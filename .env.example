TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+15551234567

# Keep live Telegram sessions, ngrok config, and tokens outside the source tree
# when using this repo as a development checkout.
PEBBLEGRAM_DATA_DIR=/srv/pebblegram/data

# Optional. If omitted during interactive Docker setup, Pebblegram generates one.
# Generate manually with: openssl rand -hex 24
PEBBLEGRAM_TOKEN=

# Send is enabled for the watch reply feature. Delete stays off by default.
TELEGRAM_ALLOW_SEND=1
TELEGRAM_ALLOW_DELETE=0

# Required only when using docker-compose.hosted.yml with Caddy.
PEBBLEGRAM_DOMAIN=pebblegram.example.com
